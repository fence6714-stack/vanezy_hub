local renderConnection
renderConnection = RunService.RenderStepped:Connect(function()
    cache.frameSkip = cache.frameSkip + 1
    if cache.frameSkip % 2 == 0 then return end
    
    if not getgenv().ESPPlayers and not getgenv().Aimbot and not getgenv().Tracers and not getgenv().Fly and not getgenv().Noclip then
        return
    end
    
    updateCache()
    local mid = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    fovCircle.Position = mid
    fovCircle.Radius = getgenv().FOVSize
    fovCircle.Visible = getgenv().Aimbot
    
    if getgenv().Aimbot then
        local target = findBestTarget()
        if target then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position, target.Position), getgenv().AimSpeed)
        end
    end
    
    if getgenv().Fly and flyBodyVelocity then
        local move = Vector3.new()
        if UIS:IsKeyDown(Enum.KeyCode.W) then move = move + Vector3.new(0, 0, -getgenv().FlySpeed) end
        if UIS:IsKeyDown(Enum.KeyCode.S) then move = move + Vector3.new(0, 0, getgenv().FlySpeed) end
        if UIS:IsKeyDown(Enum.KeyCode.A) then move = move + Vector3.new(-getgenv().FlySpeed, 0, 0) end
        if UIS:IsKeyDown(Enum.KeyCode.D) then move = move + Vector3.new(getgenv().FlySpeed, 0, 0) end
        if UIS:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0, getgenv().FlySpeed, 0) end
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then move = move + Vector3.new(0, -getgenv().FlySpeed, 0) end
        flyBodyVelocity.Velocity = Camera.CFrame:VectorToWorldSpace(move)
    end
    
    if getgenv().SpeedBoost then
        local hum = getHum()
        if hum then hum.WalkSpeed = defaultWalkSpeed * getgenv().SpeedMultiplier end
    else
        local hum = getHum()
        if hum and hum.WalkSpeed ~= defaultWalkSpeed and not getgenv().Fly then
            hum.WalkSpeed = defaultWalkSpeed
        end
    end
    
    if getgenv().GodMode then
        local hum = getHum()
        if hum then
            if hum.MaxHealth < 99999 then hum.MaxHealth = 99999 end
            if hum.Health < hum.MaxHealth then hum.Health = hum.MaxHealth end
        end
    end
    
    if getgenv().Noclip then
        local c = getChar()
        if c then
            for _, p in pairs(c:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
        end
    end
    
    if getgenv().ESPPlayers or getgenv().Tracers then
        local players = cache.players
        for i = 1, #players do
            local p = players[i]
            if p ~= Player then
                local char = p.Character
                if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                    local isTeam = isTeammate(p)
                    if not getgenv().ESPTeammates and isTeam then
                        if espCache[p] then
                            espCache[p].line.Visible = false
                            espCache[p].box.Visible = false
                        end
                        goto continueESP
                    end
                    initDraw(p)
                    local data = espCache[p]
                    local root = char.HumanoidRootPart
                    local screenPos, onScreen = getScreenData(root.Position)
                    local distance = (cache.cameraPos - root.Position).Magnitude
                    local color = isTeam and Color3.fromHSV(0.55, 1, 1) or Color3.fromHSV(math.clamp(distance / getgenv().MaxDistance, 0, 0.33), 1, 1)
                    data.line.From = mid
                    data.line.To = screenPos
                    data.line.Color = color
                    data.line.Visible = getgenv().Tracers
                    if (getgenv().ESPPlayers or (getgenv().ESPTeammates and isTeam)) and onScreen then
                        local size = math.clamp(2500 / distance, 5, 300)
                        data.box.Size = Vector2.new(size, size * 1.5)
                        data.box.Position = Vector2.new(screenPos.X - size / 2, screenPos.Y - size * 0.75)
                        data.box.Color = color
                        data.box.Visible = true
                    else
                        data.box.Visible = false
                    end
                elseif espCache[p] then
                    espCache[p].line.Visible = false
                    espCache[p].box.Visible = false
                end
                ::continueESP::
            end
        end
    end
end)

