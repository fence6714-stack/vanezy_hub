local function getScreenData(position)
    local screen, visible = Camera:WorldToViewportPoint(position)
    if visible then
        return Vector2.new(screen.X, screen.Y), true
    end
    local mid = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local diff = (Vector2.new(screen.X, screen.Y) - mid)
    if diff.Magnitude == 0 then return mid, false end
    local scale = math.min((mid.X - 20) / math.abs(diff.X), (mid.Y - 20) / math.abs(diff.Y))
    return (screen.Z < 0) and (mid - (diff * scale)) or (mid + (diff * scale)), false
end

local function isTeammate(player)
    if not Player.Team or not player.Team then return false end
    return Player.Team == player.Team
end

local silentAimTarget = nil

-- ===== ИСПРАВЛЕНО: continue заменены на goto =====
local function getSilentAimTarget()
    local target, nearest = nil, getgenv().FOVSize
    local mid = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, p in pairs(Players:GetPlayers()) do
        if p == Player then goto skipPlayer end
        if not p.Character then goto skipPlayer end
        local hum = p.Character:FindFirstChild("Humanoid")
        local head = p.Character:FindFirstChild("Head")
        if not hum or not head or hum.Health <= 0 then goto skipPlayer end
        if isTeammate(p) then goto skipPlayer end
        local screen, visible = Camera:WorldToViewportPoint(head.Position)
        if visible then
            local dist = (Vector2.new(screen.X, screen.Y) - mid).Magnitude
            if dist < getgenv().FOVSize and dist < nearest then
                nearest = dist
                target = head
            end
        end
        ::skipPlayer::
    end
    return target
end

local function silentShoot()
    if not getgenv().Aimbot then return end
    
    local target = getSilentAimTarget()
    if not target then return end
    
    local tool = Player.Character and Player.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    
    local targetPos = target.Position + Vector3.new(0, 0.5, 0)
    
    -- Отправляем выстрел в цель
    for _, obj in ipairs(tool:GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            pcall(function() obj:FireServer(targetPos, target, Vector3.new(0, 1, 0)) end)
            pcall(function() obj:FireServer(targetPos, target) end)
            pcall(function() obj:FireServer(targetPos) end)
        end
    end
    
    -- Общие названия RemoteEvent
    for _, name in ipairs({"Fire", "Shoot", "RemoteEvent", "Hit", "Replicate"}) do
        local r = tool:FindFirstChild(name)
        if r and r:IsA("RemoteEvent") then
            pcall(function() r:FireServer(targetPos, target) end)
            pcall(function() r:FireServer(targetPos) end)
        end
    end
    
    -- Для Rivals через ReplicatedStorage
    pcall(function()
        local hitRemote = game:GetService("ReplicatedStorage"):FindFirstChild("Hit")
        if hitRemote then
            hitRemote:FireServer(targetPos, target)
        end
    end)
end

-- ===== ИСПРАВЛЕНО: добавлен учет AimPart =====
local function findBestTarget()
    local target, nearest = nil, getgenv().FOVSize
    local mid = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    if aimLockTarget and aimLockTarget.Parent then
        local humanoid = aimLockTarget.Parent:FindFirstChild("Humanoid")
        if humanoid and humanoid.Health > 0 then
            local screen, visible = Camera:WorldToViewportPoint(aimLockTarget.Position)
            if visible then
                local dist = (Vector2.new(screen.X, screen.Y) - mid).Magnitude
                if dist < getgenv().FOVSize * 1.5 then
                    return aimLockTarget
                end
            end
        end
    end
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player and p.Character then
            local humanoid = p.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                if not isTeammate(p) then
                    local parts = {getgenv().AimPart, "Torso", "HumanoidRootPart"}
                    for _, partName in ipairs(parts) do
                        local hitPart = p.Character:FindFirstChild(partName)
                        if hitPart then
                            local screen, visible = Camera:WorldToViewportPoint(hitPart.Position)
                            if visible then
                                local dist = (Vector2.new(screen.X, screen.Y) - mid).Magnitude
                                local score = dist
                                if partName == "Head" then
                                    score = score * 0.7
                                end
                                if dist < 100 then
                                    score = score * 0.5
                                end
                                if getgenv().ESPWallCheck then
                                    local myHRP = getHRP()
                                    if myHRP and not hasLOS(myHRP.Position, hitPart.Position) then
                                        goto continuePart
                                    end
                                end
                                if score < nearest then
                                    nearest = score
                                    target = hitPart
                                end
                            end
                        end
                        ::continuePart::
                    end
                end
            end
        end
    end
    
    if target then
        aimLockTarget = target
    end
    
    return target
end

-- ===== ИСПРАВЛЕНО: удален mouse1click =====
local function performShoot()
    local tool = Player.Character and Player.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    
    if tool:FindFirstChild("RemoteFunction") then
        pcall(function() tool.RemoteFunction:InvokeServer("Fire") end)
    end
    
    pcall(function() tool:Activate() end)
    
    if UIS.TouchEnabled then
        pcall(function()
            local mouse = Player:GetMouse()
            if mouse then
                mouse.Button1Down:Fire()
                task.wait(0.02)
                mouse.Button1Up:Fire()
            end
        end)
    else
        -- Эмуляция через UIS (для эксплоитов без mouse1click)
        pcall(function()
            local mouse = Player:GetMouse()
            if mouse and mouse.Button1Down then
                mouse.Button1Down:Fire()
                task.wait(0.02)
                mouse.Button1Up:Fire()
            end
        end)
    end
end

local function autoShoot()
    if not getgenv().Aimbot then return end
    if not getgenv().AutoShoot then return end
    
    local target = aimLockTarget
    if not target then return end
    if not target.Parent or not target.Parent:FindFirstChild("Humanoid") then return end
    if target.Parent.Humanoid.Health <= 0 then return end
    
    local screenPos, onScreen = Camera:WorldToViewportPoint(target.Position)
    if not onScreen then return end
    
    local mid = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local distToCenter = (Vector2.new(screenPos.X, screenPos.Y) - mid).Magnitude
    
    if distToCenter > getgenv().AutoShootFOV then return end
    
    local currentTime = tick()
    if currentTime - lastShootTime < getgenv().AutoShootDelay then return end
    
    lastShootTime = currentTime
    performShoot()
end

task.spawn(function()
    while true do
        task.wait(0.05)
        pcall(autoShoot)
    end
end)

