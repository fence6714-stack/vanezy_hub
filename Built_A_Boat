local function initDraw(player)
    if espCache[player] then return end
    espCache[player] = {
        line = Drawing.new("Line"),
        box = Drawing.new("Square")
    }
    espCache[player].line.Thickness = 1.5
    espCache[player].box.Thickness = 1.5
    espCache[player].box.Filled = false
end

local function getScreenData(position)
    local screen, visible = Camera:WorldToViewportPoint(position)
    if visible then
        return Vector2.new(screen.X, screen.Y), true
    end
    local mid = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local diff = (Vector2.new(screen.X, screen.Y) - mid)
    if diff.Magnitude == 0 then return mid, false end
    local scale = math.min((mid.X - 20) / math.abs(diff.X), (mid.Y - 20) / math.abs(diff.Y))
    return (screen.Z < 0) and (mid - (diff * scale)) or (mid + (diff * scale)), false
end

local function isTeammate(player)
    if not Player.Team or not player.Team then return false end
    return Player.Team == player.Team
end

local function findBestTarget()
    local target, nearest = nil, getgenv().FOVSize
    local mid = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    if aimLockTarget and aimLockTarget.Parent then
        local humanoid = aimLockTarget.Parent:FindFirstChild("Humanoid")
        if humanoid and humanoid.Health > 0 then
            local screen, visible = Camera:WorldToViewportPoint(aimLockTarget.Position)
            if visible then
                local dist = (Vector2.new(screen.X, screen.Y) - mid).Magnitude
                if dist < getgenv().FOVSize * 1.5 then
                    return aimLockTarget
                end
            end
        end
    end
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player and p.Character then
            local humanoid = p.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                if not isTeammate(p) then
                    local parts = {"Head", "Torso", "HumanoidRootPart"}
                    for _, partName in ipairs(parts) do
                        local hitPart = p.Character:FindFirstChild(partName)
                        if hitPart then
                            local screen, visible = Camera:WorldToViewportPoint(hitPart.Position)
                            if visible then
                                local dist = (Vector2.new(screen.X, screen.Y) - mid).Magnitude
                                local score = dist
                                if partName == "Head" then
                                    score = score * 0.7
                                end
                                if dist < 100 then
                                    score = score * 0.5
                                end
                                if score < nearest then
                                    nearest = score
                                    target = hitPart
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    if target then
        aimLockTarget = target
    end
    
    return target
end

local function performShoot()
    local tool = Player.Character and Player.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    
    if tool:FindFirstChild("RemoteFunction") then
        pcall(function() tool.RemoteFunction:InvokeServer("Fire") end)
    end
    
    pcall(function() tool:Activate() end)
    
    if UIS.TouchEnabled then
        pcall(function()
            local mouse = Player:GetMouse()
            if mouse then
                mouse.Button1Down:Fire()
                task.wait(0.02)
                mouse.Button1Up:Fire()
            end
        end)
    else
        pcall(function()
            if mouse1click then mouse1click() end
        end)
    end
end

local function autoShoot()
    if not getgenv().Aimbot then return end
    if not getgenv().AutoShoot then return end
    
    local target = aimLockTarget
    if not target then return end
    if not target.Parent or not target.Parent:FindFirstChild("Humanoid") then return end
    if target.Parent.Humanoid.Health <= 0 then return end
    
    local screenPos, onScreen = Camera:WorldToViewportPoint(target.Position)
    if not onScreen then return end
    
    local mid = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local distToCenter = (Vector2.new(screenPos.X, screenPos.Y) - mid).Magnitude
    
    if distToCenter > getgenv().AutoShootFOV then return end
    
    local currentTime = tick()
    if currentTime - lastShootTime < getgenv().AutoShootDelay then return end
    
    lastShootTime = currentTime
    performShoot()
end

task.spawn(function()
    while true do
        task.wait(0.05)
        pcall(autoShoot)
    end
end)

local function cleanupESP()
    getgenv().ESPPlayers = false
    getgenv().ESPTeammates = false
    getgenv().Tracers = false
    getgenv().Aimbot = false
    for _, data in pairs(espCache) do
        if data.line then data.line:Remove() end
        if data.box then data.box:Remove() end
    end
    table.clear(espCache)
    if fovCircle then fovCircle:Remove() end
end

local renderConnection
renderConnection = RunService.RenderStepped:Connect(function()
    local mid = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    fovCircle.Position = mid
    fovCircle.Radius = getgenv().FOVSize
    fovCircle.Visible = getgenv().Aimbot
    if getgenv().Aimbot then
        local target = findBestTarget()
        if target then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position, target.Position), getgenv().AimSpeed)
        end
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player then
            local char = p.Character
            if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                local isTeam = isTeammate(p)
                if not getgenv().ESPTeammates and isTeam then
                    if espCache[p] then
                        espCache[p].line.Visible = false
                        espCache[p].box.Visible = false
                    end
                    continue
                end
                initDraw(p)
                local data = espCache[p]
                local root = char.HumanoidRootPart
                local screenPos, onScreen = getScreenData(root.Position)
                local distance = (Camera.CFrame.Position - root.Position).Magnitude
                local color = isTeam and Color3.fromHSV(0.55, 1, 1) or Color3.fromHSV(math.clamp(distance / getgenv().MaxDistance, 0, 0.33), 1, 1)
                data.line.From = mid
                data.line.To = screenPos
                data.line.Color = color
                data.line.Visible = getgenv().Tracers
                if (getgenv().ESPPlayers or (getgenv().ESPTeammates and isTeam)) and onScreen then
                    local size = math.clamp(2500 / distance, 5, 300)
                    data.box.Size = Vector2.new(size, size * 1.5)
                    data.box.Position = Vector2.new(screenPos.X - size / 2, screenPos.Y - size * 0.75)
                    data.box.Color = color
                    data.box.Visible = true
                else
                    data.box.Visible = false
                end
            elseif espCache[p] then
                espCache[p].line.Visible = false
                espCache[p].box.Visible = false
            end
        end
    end
end)

