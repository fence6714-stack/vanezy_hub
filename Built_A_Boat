    line.BorderSizePixel = 0
    line.Visible = false
    line.Parent = tabBtn
    Instance.new("UICorner", line).CornerRadius = UDim.new(1, 0)

    local iconBtn = Instance.new("TextButton")
    iconBtn.Size = UDim2.new(0, 32, 0, 32)
    iconBtn.Position = UDim2.new(0.5, -16, 0, 7 + (i - 1) * 40)
    iconBtn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
    iconBtn.BackgroundTransparency = 1
    iconBtn.BorderSizePixel = 0
    iconBtn.Text = tab.Icon
    iconBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
    iconBtn.Font = Enum.Font.GothamBold
    iconBtn.TextSize = 16
    iconBtn.Visible = false
    iconBtn.Parent = SidePanel
    Instance.new("UICorner", iconBtn).CornerRadius = UDim.new(0, 6)

    local content = Instance.new("ScrollingFrame")
    content.Size = UDim2.new(1, 0, 1, 0)
    content.BackgroundTransparency = 1
    content.ScrollBarThickness = 3
    content.ScrollBarImageColor3 = Color3.fromRGB(60, 60, 60)
    content.CanvasSize = UDim2.new(0, 0, 0, 0)
    content.Visible = false
    content.Parent = ContentPanel

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 5)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = content

    content.ChildAdded:Connect(function()
        local totalH = 0
        for _, child in pairs(content:GetChildren()) do
            if child:IsA("Frame") or child:IsA("TextButton") or child:IsA("TextLabel") then
                totalH = totalH + child.AbsoluteSize.Y + 5
            end
        end
        content.CanvasSize = UDim2.new(0, 0, 0, totalH + 10)
    end)

    TabButtons[tab.Name] = tabBtn
    TabContents[tab.Name] = content
    TabIconsOnly[tab.Name] = iconBtn
    TabLines[tab.Name] = line

    local function switchToTab()
        if currentTab == tab.Name then return end
        local oldTab = currentTab
        currentTab = tab.Name

        if oldTab and TabLines[oldTab] and TabLines[oldTab].Visible then
            TweenService:Create(TabLines[oldTab], TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                Position = UDim2.new(-0.3, 0, 1, -4)
            }):Play()
            task.delay(0.25, function()
                if TabLines[oldTab] then TabLines[oldTab].Visible = false end
                if TabLines[oldTab] then TabLines[oldTab].Position = UDim2.new(0.3, 0, 1, -4) end
            end)
        end

        local oldContent = nil
        for _, cnt in pairs(TabContents) do
            if cnt.Visible then oldContent = cnt break end
        end
        if oldContent then
            for _, child in pairs(oldContent:GetChildren()) do
                if child:IsA("TextLabel") or child:IsA("TextButton") then
