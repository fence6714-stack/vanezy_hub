    if settingsOpen then
        settingsOpen = false
        SettingsExpanded:TweenSize(UDim2.new(0, 0, 0, 32), "Out", "Quad", 0.25, true)
    end
    
    -- ИСПРАВЛЕНО: Скрываем контент настроек и все его элементы
    if SettingsContent then 
        SettingsContent.Visible = false
        for _, child in pairs(SettingsContent:GetChildren()) do
            if child:IsA("Frame") or child:IsA("TextButton") or child:IsA("TextLabel") or child:IsA("ScrollingFrame") then
                child.Visible = false
            end
        end
    end
    
    -- Скрываем все вкладки
