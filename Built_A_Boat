local function hideAllTabs()
    HeaderSettingsBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    HeaderSettingsBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
    for _, cnt in pairs(TabContents) do
        if cnt then cnt.Visible = false end
    end
    for name, btn in pairs(TabButtons) do
        if btn then
            btn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            btn.BackgroundTransparency = 1
            btn.TextColor3 = Color3.fromRGB(180, 180, 180)
        end
        if TabLines[name] then
            TabLines[name].Visible = false
        end
    end
    for _, btn in pairs(TabIconsOnly) do
        if btn then
            btn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            btn.BackgroundTransparency = 1
            btn.TextColor3 = Color3.fromRGB(180, 180, 180)
        end
    end
end

