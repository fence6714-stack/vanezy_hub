local function updateStatusBar()
    local activeFuncs = {}
    if getgenv().ESPPlayers then table.insert(activeFuncs, {name = "ESP", key = "ESPPlayers"}) end
    if getgenv().ESPTeammates then table.insert(activeFuncs, {name = "ESP Team", key = "ESPTeammates"}) end
    if getgenv().Aimbot then table.insert(activeFuncs, {name = "Aim", key = "Aimbot"}) end
    if getgenv().Tracers then table.insert(activeFuncs, {name = "Trace", key = "Tracers"}) end
    if getgenv().AntiAFK then table.insert(activeFuncs, {name = "AFK", key = "AntiAFK"}) end
    if getgenv().AutoShoot then table.insert(activeFuncs, {name = "Shoot", key = "AutoShoot"}) end
    
    if #activeFuncs == 0 then
        StatusText.Text = "No functions active"
        leftArrow.Visible = false
        rightArrow.Visible = false
        MinLeftArrow.Visible = false
        MinRightArrow.Visible = false
        StatusToggleBg.Visible = false
        return
    end
    
    local currentIndex = tonumber(StatusBar:GetAttribute("CurrentIndex")) or 1
    if currentIndex > #activeFuncs then currentIndex = 1 end
    if currentIndex < 1 then currentIndex = 1 end
    
    StatusText.Text = activeFuncs[currentIndex].name
    StatusBar:SetAttribute("CurrentIndex", currentIndex)
    StatusBar:SetAttribute("CurrentKey", activeFuncs[currentIndex].key)
    
    if isMinimized then
        leftArrow.Visible = false
        rightArrow.Visible = false
        MinLeftArrow.Visible = true
        MinRightArrow.Visible = true
        
        if #activeFuncs <= 1 then
            MinLeftArrow.TextColor3 = Color3.fromRGB(80, 80, 80)
            MinRightArrow.TextColor3 = Color3.fromRGB(80, 80, 80)
        else
            MinLeftArrow.TextColor3 = (currentIndex > 1) and Color3.fromRGB(200, 200, 200) or Color3.fromRGB(80, 80, 80)
            MinRightArrow.TextColor3 = (currentIndex < #activeFuncs) and Color3.fromRGB(200, 200, 200) or Color3.fromRGB(80, 80, 80)
        end
        
        local key = activeFuncs[currentIndex].key
        if getgenv()[key] then
            StatusToggleBg.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
            StatusToggleDot:TweenPosition(UDim2.new(1, -16, 0.5, -7), "Out", "Quad", 0.2, true)
        else
            StatusToggleBg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            StatusToggleDot:TweenPosition(UDim2.new(0, 2, 0.5, -7), "Out", "Quad", 0.2, true)
        end
    else
        MinLeftArrow.Visible = false
        MinRightArrow.Visible = false
        StatusToggleBg.Visible = false
        leftArrow.Visible = false
        rightArrow.Visible = false
    end
end

