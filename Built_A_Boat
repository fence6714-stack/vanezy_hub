local activeNotifications = {}

local function removeNotification(nf, customButtons)
    local idx = nil
    for i, v in ipairs(activeNotifications) do
        if v == nf then idx = i; break end
    end
    if idx then table.remove(activeNotifications, idx) end
    for i, n in ipairs(activeNotifications) do
        local ny = 5 + ((i - 1) * (customButtons and 100 or 72))
        pcall(function()
            local isConfirm = customButtons
            local isFirst = (n.Title == "Notification" and n.Message:find("Vanezy Scripts"))
            local tx, toff = 0.5, -135
            if not isConfirm and not isFirst then
                tx, toff = 1, -270
            end
            TweenService:Create(n, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Position = UDim2.new(tx, toff, 0, ny)
            }):Play()
        end)
    end
end

function createNotification(title, message, duration, customButtons)
    duration = duration or 3
    while #activeNotifications >= 5 do
        local oldest = table.remove(activeNotifications, 1)
        if oldest and oldest.Parent then oldest:Destroy() end
