    while #activeNotifications >= 5 do
        local oldest = table.remove(activeNotifications, 1)
        if oldest and oldest.Parent then oldest:Destroy() end
    end
    
    local nf = Instance.new("Frame")
    local isSpecial = (title == "Notification" and message:find("Vanezy Scripts")) or customButtons
    local isConfirm = customButtons
    
    if isSpecial or isConfirm then
        nf.Size = UDim2.new(0, 270, 0, customButtons and 90 or 62)
    else
        nf.Size = UDim2.new(0, 200, 0, customButtons and 70 or 48)
    end
    
    nf.Position = UDim2.new(0.5, -135, 0, -100)
    nf.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    nf.BorderSizePixel = 0
    nf.ClipsDescendants = true
    nf.Parent = NotifGui
    Instance.new("UICorner", nf).CornerRadius = UDim.new(0, 12)
    Instance.new("UIStroke", nf).Color = Color3.fromRGB(40, 40, 40)
    Instance.new("UIStroke", nf).Thickness = 1
    
    local gradient = Instance.new("UIGradient", nf)
    local hue = 0
    task.spawn(function()
        while nf and nf.Parent do
            hue = (hue + 0.005) % 1
            pcall(function()
                gradient.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromHSV(hue, 0.5, 1)),
                    ColorSequenceKeypoint.new(0.3, Color3.fromHSV((hue + 0.3) % 1, 0.5, 1)),
                    ColorSequenceKeypoint.new(0.6, Color3.fromHSV((hue + 0.6) % 1, 0.5, 1)),
                    ColorSequenceKeypoint.new(1, Color3.fromHSV(hue, 0.5, 1)),
                })
            end)
            task.wait(0.03)
        end
    end)
    
    local titleLabel = Instance.new("TextLabel")
    if isSpecial or isConfirm then
        titleLabel.Size = UDim2.new(1, customButtons and -12 or -35, 0, 20)
        titleLabel.Position = UDim2.new(0, 12, 0, 8)
        titleLabel.TextSize = 12
    else
        titleLabel.Size = UDim2.new(1, customButtons and -8 or -25, 0, 16)
        titleLabel.Position = UDim2.new(0, 8, 0, 6)
        titleLabel.TextSize = 10
    end
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = title
    titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.ZIndex = 10
    titleLabel.Parent = nf
    
    local msgLabel = Instance.new("TextLabel")
    if isSpecial or isConfirm then
        msgLabel.Size = UDim2.new(1, -35, 0, customButtons and 20 or 18)
        msgLabel.Position = UDim2.new(0, 12, 0, 28)
        msgLabel.TextSize = 9
    else
        msgLabel.Size = UDim2.new(1, -25, 0, customButtons and 16 or 14)
        msgLabel.Position = UDim2.new(0, 8, 0, 22)
        msgLabel.TextSize = 8
    end
    msgLabel.BackgroundTransparency = 1
    msgLabel.Text = message
    msgLabel.TextColor3 = Color3.fromRGB(170, 170, 170)
    msgLabel.Font = Enum.Font.Gotham
    msgLabel.TextXAlignment = Enum.TextXAlignment.Left
    msgLabel.RichText = true
    msgLabel.ZIndex = 10
    msgLabel.Parent = nf
    
    local closeBtn
    if not customButtons then
        closeBtn = Instance.new("TextButton")
        if isSpecial then
            closeBtn.Size = UDim2.new(0, 18, 0, 18)
            closeBtn.Position = UDim2.new(1, -24, 0, 7)
            closeBtn.TextSize = 13
        else
            closeBtn.Size = UDim2.new(0, 14, 0, 14)
            closeBtn.Position = UDim2.new(1, -18, 0, 5)
            closeBtn.TextSize = 10
        end
        closeBtn.BackgroundTransparency = 1
        closeBtn.Text = "x"
        closeBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
        closeBtn.Font = Enum.Font.GothamBold
        closeBtn.ZIndex = 10
        closeBtn.Parent = nf
    end
    
    local timeLine = Instance.new("Frame")
    timeLine.Size = UDim2.new(1, 0, 0, 2)
    timeLine.Position = UDim2.new(0, 0, 1, -2)
    timeLine.BackgroundColor3 = Color3.fromRGB(255, 90, 90)
    timeLine.BorderSizePixel = 0
    timeLine.ZIndex = 10
    timeLine.Parent = nf
    
    local yPos
    if isSpecial or isConfirm then
        yPos = 50 + (#activeNotifications * (customButtons and 100 or 72))
    else
        yPos = -5 + (#activeNotifications * (customButtons and 80 or 55))
    end
    
    local xPos
    if isSpecial or isConfirm then
        xPos = 0.5
        local offset = -135
        nf.Position = UDim2.new(xPos, offset, 0, -100)
        TweenService:Create(nf, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(xPos, offset, 0, yPos)
        }):Play()
    else
        xPos = 1
        local offset = -210
        nf.Position = UDim2.new(xPos, offset, 0, -100)
        TweenService:Create(nf, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(xPos, offset, 0, yPos)
        }):Play()
    end
    
    local lineTween = TweenService:Create(timeLine, TweenInfo.new(duration, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 0, 2)})
    lineTween:Play()
    
    local isClosed = false
    local function closeNotification()
        if isClosed then return end
        isClosed = true
        pcall(function() lineTween:Cancel() end)
        local ht = TweenService:Create(nf, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(xPos, (xPos == 0.5 and -135 or -210), 0, -100)})
        ht:Play()
        ht.Completed:Connect(function()
            if nf and nf.Parent then nf:Destroy() end
            removeNotification(nf, customButtons)
        end)
    end
    
    if closeBtn then closeBtn.MouseButton1Click:Connect(closeNotification) end
    task.delay(duration, function() if not isClosed then closeNotification() end end)
    table.insert(activeNotifications, nf)
    
    if customButtons then
        local btnFrame = Instance.new("Frame")
        btnFrame.Size = UDim2.new(1, 0, 0, 30)
        btnFrame.Position = UDim2.new(0, 0, 0, 52)
        btnFrame.BackgroundTransparency = 1
        btnFrame.ZIndex = 10
        btnFrame.Parent = nf
        
        local yesBtn = Instance.new("TextButton")
        yesBtn.Size = UDim2.new(0, 80, 0, 26)
        yesBtn.Position = UDim2.new(0.5, -90, 0.5, -13)
        yesBtn.BackgroundColor3 = Color3.fromRGB(40, 140, 40)
        yesBtn.BorderSizePixel = 0
        yesBtn.Text = "✅"
        yesBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        yesBtn.Font = Enum.Font.GothamBold
        yesBtn.TextSize = 18
        yesBtn.Parent = btnFrame
        Instance.new("UICorner", yesBtn).CornerRadius = UDim.new(0, 8)
        
        local noFrame = Instance.new("Frame")
        noFrame.Size = UDim2.new(0, 80, 0, 26)
        noFrame.Position = UDim2.new(0.5, 10, 0.5, -13)
        noFrame.BackgroundColor3 = Color3.fromRGB(180, 30, 30)
        noFrame.BorderSizePixel = 0
        noFrame.Parent = btnFrame
        Instance.new("UICorner", noFrame).CornerRadius = UDim.new(0, 8)
        Instance.new("UIStroke", noFrame).Color = Color3.fromRGB(255, 0, 0)
        Instance.new("UIStroke", noFrame).Thickness = 2
        
        local noBtn = Instance.new("TextButton")
        noBtn.Size = UDim2.new(1, 0, 1, 0)
        noBtn.BackgroundTransparency = 1
        noBtn.Text = "x"
        noBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        noBtn.Font = Enum.Font.GothamBold
        noBtn.TextSize = 20
        noBtn.Parent = noFrame
        
        return nf, yesBtn, noBtn, closeNotification
    end
    return nf
end

function copyToClipboard(text, label)
    if pcall(function() setclipboard(text) end) then
        createNotification("Notification", "✅ Copied: " .. (label or text), 5)
    end
end

